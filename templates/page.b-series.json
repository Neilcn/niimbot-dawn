      "settings": {
        "custom_liquid": "<style>\n  .bundle-page {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 40px 20px;\n  }\n  .page-title {\n    text-align: center;\n    font-size: 32px;\n    margin-bottom: 40px;\n  }\n  .two-columns {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 40px;\n    justify-content: center;\n  }\n  .product-card {\n    flex: 1;\n    min-width: 350px;\n    background: #fff;\n    border-radius: 24px;\n    padding: 24px;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.08);\n    text-align: center;\n  }\n  .product-card h2 {\n    font-size: 24px;\n    margin-bottom: 8px;\n  }\n  .product-card .subtitle {\n    color: #666;\n    font-size: 14px;\n    margin-bottom: 20px;\n    padding-bottom: 16px;\n    border-bottom: 1px solid #eee;\n  }\n  .product-card img {\n    width: 100%;\n    aspect-ratio: 1;\n    object-fit: contain;\n    border-radius: 16px;\n    margin-bottom: 20px;\n    background: #f8f9fa;\n  }\n  /* Globo变体样式 */\n  .globo-swatch-product-detail {\n    margin: 15px 0;\n  }\n  .price {\n    font-size: 24px;\n    font-weight: bold;\n    color: #b12704;\n    margin: 15px 0;\n  }\n  .add-to-cart {\n    background: #000;\n    color: white;\n    border: none;\n    padding: 12px 28px;\n    border-radius: 40px;\n    font-size: 16px;\n    cursor: pointer;\n    width: 100%;\n    transition: opacity 0.2s;\n  }\n  .add-to-cart:hover {\n    opacity: 0.8;\n  }\n  @media (max-width: 768px) {\n    .two-columns {\n      flex-direction: column;\n    }\n  }\n</style>\n\n<div class=\"bundle-page\">\n\n  <h1 class=\"page-title\">B Series Label Packs</h1>\n\n  <div class=\"two-columns\">\n\n    <!-- ========== 左侧：白色系列 ========== -->\n    <div class=\"product-card\">\n      <h2>White Series</h2>\n      <div class=\"subtitle\">Waterproof & Oil-proof — B21/B1/B3S/B31</div>\n      \n      <!-- 产品主图 -->\n      {% assign white = all_products['niimbot-label-white'] %}\n      <img id=\"white-main-image\" src=\"{{ white.featured_image | img_url: 'large' }}\" alt=\"White Series\">\n      \n      <!-- Globo变体容器 - Globo会自动在这里渲染变体选项 -->\n      <div class=\"globo-swatch-product-detail\" data-product-id=\"{{ white.id }}\"></div>\n      \n      <!-- 价格和加购按钮 -->\n      <div id=\"white-price\" class=\"price\">{{ white.price | money }}</div>\n      <button id=\"white-add-to-cart\" class=\"add-to-cart\" data-product-id=\"{{ white.id }}\">Add to Cart →</button>\n    </div>\n\n    <!-- ========== 右侧：功能性系列 ========== -->\n    <div class=\"product-card\">\n      <h2>Functional Series</h2>\n      <div class=\"subtitle\">Cable Markers & More — B21/B1/B3S/B31</div>\n      \n      {% assign functional = all_products['niimbot-b21-b3s-b1-b31-label-functional'] %}\n      <img id=\"functional-main-image\" src=\"{{ functional.featured_image | img_url: 'large' }}\" alt=\"Functional Series\">\n      \n      <!-- Globo变体容器 -->\n      <div class=\"globo-swatch-product-detail\" data-product-id=\"{{ functional.id }}\"></div>\n      \n      <div id=\"functional-price\" class=\"price\">{{ functional.price | money }}</div>\n      <button id=\"functional-add-to-cart\" class=\"add-to-cart\" data-product-id=\"{{ functional.id }}\">Add to Cart →</button>\n    </div>\n\n  </div>\n\n</div>\n\n<script>\n// 等待Globo插件加载完成后，手动触发渲染\ndocument.addEventListener('DOMContentLoaded', function() {\n  // 找到所有Globo容器，让Globo去渲染它们\n  const globoContainers = document.querySelectorAll('.globo-swatch-product-detail');\n  \n  globoContainers.forEach(container => {\n    const productId = container.dataset.productId;\n    if (productId && window.Globo) {\n      // 触发Globo的渲染函数\n      if (typeof window.Globo.initProductSwatch === 'function') {\n        window.Globo.initProductSwatch(container, productId);\n      }\n    }\n  });\n});\n\n// 价格和加购功能\ndocument.querySelectorAll('.add-to-cart').forEach(btn => {\n  btn.addEventListener('click', async function() {\n    const productId = this.dataset.productId;\n    // 获取Globo当前选中的变体\n    const container = this.closest('.product-card').querySelector('.globo-swatch-product-detail');\n    const selectedVariant = container?.querySelector('.selected')?.dataset?.variantId;\n    \n    if (selectedVariant) {\n      fetch('/cart/add.js', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ id: parseInt(selectedVariant), quantity: 1 })\n      }).then(() => {\n        btn.textContent = '✓ Added!';\n        setTimeout(() => btn.textContent = 'Add to Cart →', 1500);\n      }).catch(() => alert('Error adding to cart'));\n    } else {\n      alert('Please select a variant first');\n    }\n  });\n});\n</script>",
