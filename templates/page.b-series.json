      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div style=\"max-width: 1400px; margin: 0 auto; padding: 40px 20px;\">\n  \n  <h1 style=\"text-align: center; margin-bottom: 40px;\">📦 Mix & Match Label Pack</h1>\n  \n  <div style=\"display: flex; flex-wrap: wrap; gap: 40px;\">\n    \n    <!-- ========== 左侧：White 产品 ========== -->\n    {% assign white = all_products['niimbot-b21-b1-b3s-b31-label-white'] %}\n    {% if white != blank %}\n    <div style=\"flex: 1; min-width: 320px; background: #fff; border-radius: 20px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);\">\n      \n      <h2 style=\"font-size: 20px; margin-bottom: 8px;\">{{ white.title }}</h2>\n      \n      <!-- 主图 -->\n      <img id=\"white-main-image\" src=\"{{ white.featured_image | img_url: 'large' }}\" style=\"width: 100%; aspect-ratio: 1; object-fit: contain; background: #f5f5f5; border-radius: 16px; margin: 20px 0;\">\n      \n      <!-- 变体按钮区域 -->\n      <div style=\"margin: 20px 0; display: flex; flex-wrap: wrap; gap: 8px;\">\n        {% for variant in white.variants %}\n          <button class=\"white-variant-btn\" \n                  data-variant-id=\"{{ variant.id }}\" \n                  data-variant-image=\"{{ variant.image.src | default: white.featured_image | img_url: 'large' }}\" \n                  data-variant-price=\"{{ variant.price | money }}\"\n                  data-product-handle=\"{{ white.handle }}\"\n                  data-variant-title=\"{{ variant.title }}\"\n                  style=\"padding: 8px 16px; border: 1px solid #ddd; border-radius: 40px; background: white; cursor: pointer; font-size: 13px;\">\n            {{ variant.title }} - {{ variant.price | money }}\n          </button>\n        {% endfor %}\n      </div>\n      \n      <!-- 价格和加购按钮区域 -->\n      <div style=\"margin: 20px 0; padding: 16px; background: #f8f9fa; border-radius: 12px; display: flex; justify-content: space-between; align-items: center;\">\n        <span id=\"white-price\" style=\"font-size: 24px; font-weight: bold; color: #b12704;\">{{ white.price | money }}</span>\n        <button id=\"white-add-to-cart\" class=\"add-to-cart-btn\" data-variant-id=\"{{ white.variants[0].id }}\" style=\"background: #000; color: white; border: none; padding: 10px 24px; border-radius: 40px; cursor: pointer;\">Add to Cart →</button>\n      </div>\n      \n      <!-- 左侧详情图片区域 -->\n      <div style=\"margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;\">\n        <h3 style=\"font-size: 16px; margin-bottom: 12px;\">📷 Product Images Gallery</h3>\n        <div id=\"white-detail-gallery\" style=\"display: flex; flex-wrap: wrap; gap: 10px; min-height: 120px;\">\n          <p style=\"color: #999; width: 100%; text-align: center; font-size: 13px;\">Click variant to view images</p>\n        </div>\n      </div>\n      \n    </div>\n    {% else %}\n    <div style=\"flex:1; padding:40px; background:#f8f9fa; border-radius:20px; color:red;\">\n      ❌ Product not found: White\n    </div>\n    {% endif %}\n    \n    <!-- ========== 右侧：Functional 产品 ========== -->\n    {% assign functional = all_products['niimbot-b21-b1-b3s-b31-label-functional'] %}\n    {% if functional != blank %}\n    <div style=\"flex: 1; min-width: 320px; background: #fff; border-radius: 20px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);\">\n      \n      <h2 style=\"font-size: 20px; margin-bottom: 8px;\">{{ functional.title }}</h2>\n      \n      <!-- 主图 -->\n      <img id=\"functional-main-image\" src=\"{{ functional.featured_image | img_url: 'large' }}\" style=\"width: 100%; aspect-ratio: 1; object-fit: contain; background: #f5f5f5; border-radius: 16px; margin: 20px 0;\">\n      \n      <!-- 变体按钮区域 -->\n      <div style=\"margin: 20px 0; display: flex; flex-wrap: wrap; gap: 8px;\">\n        {% for variant in functional.variants %}\n          <button class=\"functional-variant-btn\" \n                  data-variant-id=\"{{ variant.id }}\" \n                  data-variant-image=\"{{ variant.image.src | default: functional.featured_image | img_url: 'large' }}\" \n                  data-variant-price=\"{{ variant.price | money }}\"\n                  data-product-handle=\"{{ functional.handle }}\"\n                  data-variant-title=\"{{ variant.title }}\"\n                  style=\"padding: 8px 16px; border: 1px solid #ddd; border-radius: 40px; background: white; cursor: pointer; font-size: 13px;\">\n            {{ variant.title }} - {{ variant.price | money }}\n          </button>\n        {% endfor %}\n      </div>\n      \n      <!-- 价格和加购按钮区域 -->\n      <div style=\"margin: 20px 0; padding: 16px; background: #f8f9fa; border-radius: 12px; display: flex; justify-content: space-between; align-items: center;\">\n        <span id=\"functional-price\" style=\"font-size: 24px; font-weight: bold; color: #b12704;\">{{ functional.price | money }}</span>\n        <button id=\"functional-add-to-cart\" class=\"add-to-cart-btn\" data-variant-id=\"{{ functional.variants[0].id }}\" style=\"background: #000; color: white; border: none; padding: 10px 24px; border-radius: 40px; cursor: pointer;\">Add to Cart →</button>\n      </div>\n      \n      <!-- 右侧详情图片区域 -->\n      <div style=\"margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;\">\n        <h3 style=\"font-size: 16px; margin-bottom: 12px;\">📷 Product Images Gallery</h3>\n        <div id=\"functional-detail-gallery\" style=\"display: flex; flex-wrap: wrap; gap: 10px; min-height: 120px;\">\n          <p style=\"color: #999; width: 100%; text-align: center; font-size: 13px;\">Click variant to view images</p>\n        </div>\n      </div>\n      \n    </div>\n    {% else %}\n    <div style=\"flex:1; padding:40px; background:#f8f9fa; border-radius:20px; color:red;\">\n      ❌ Product not found: Functional\n    </div>\n    {% endif %}\n    \n  </div>\n  \n</div>\n\n<script>\n(function() {\n  \n  // 存储产品的详情图片数据\n  const productImagesCache = {};\n  \n  // 加载产品的所有图片（除主图外）\n  async function loadProductImages(productHandle) {\n    if (productImagesCache[productHandle]) {\n      return productImagesCache[productHandle];\n    }\n    \n    try {\n      const response = await fetch(`/products/${productHandle}.json`);\n      const data = await response.json();\n      const product = data.product;\n      \n      if (product && product.images) {\n        const featuredId = product.featured_image?.id;\n        const detailImages = product.images.filter(img => img.id !== featuredId);\n        productImagesCache[productHandle] = detailImages;\n        return detailImages;\n      }\n      return [];\n    } catch (error) {\n      console.error('Error loading product images:', error);\n      return [];\n    }\n  }\n  \n  // 渲染详情图片到指定画廊\n  function renderGallery(galleryId, images, variantTitle = '') {\n    const gallery = document.getElementById(galleryId);\n    if (!gallery) return;\n    \n    if (!images || images.length === 0) {\n      gallery.innerHTML = '<p style=\"color: #999; width: 100%; text-align: center; font-size: 13px;\">No images found. Please upload images in product Media section.</p>';\n      return;\n    }\n    \n    let html = '';\n    if (variantTitle) {\n      html += `<p style=\"width: 100%; margin-bottom: 10px; font-size: 12px; color: #666;\">Variant: ${variantTitle}</p>`;\n    }\n    images.forEach(img => {\n      html += `<img src=\"${img.src}\" style=\"width: 80px; height: 80px; object-fit: cover; border-radius: 10px; border: 1px solid #eee; cursor: pointer;\" onclick=\"window.open('${img.src}', '_blank')\">`;\n    });\n    gallery.innerHTML = html;\n  }\n  \n  // 处理 White 变体点击\n  async function onWhiteVariantClick(productHandle, variantTitle) {\n    const detailImages = await loadProductImages(productHandle);\n    renderGallery('white-detail-gallery', detailImages, variantTitle);\n  }\n  \n  // 处理 Functional 变体点击\n  async function onFunctionalVariantClick(productHandle, variantTitle) {\n    const detailImages = await loadProductImages(productHandle);\n    renderGallery('functional-detail-gallery', detailImages, variantTitle);\n  }\n  \n  // 初始化\n  function init() {\n    \n    // ========== White 产品 ==========\n    const whiteVariants = document.querySelectorAll('.white-variant-btn');\n    const whiteMainImage = document.getElementById('white-main-image');\n    const whitePrice = document.getElementById('white-price');\n    const whiteAddToCart = document.getElementById('white-add-to-cart');\n    \n    if (whiteVariants.length > 0) {\n      whiteVariants.forEach(btn => {\n        btn.addEventListener('click', async function(e) {\n          e.preventDefault();\n          \n          const variantId = this.getAttribute('data-variant-id');\n          const variantImage = this.getAttribute('data-variant-image');\n          const variantPrice = this.getAttribute('data-variant-price');\n          const productHandle = this.getAttribute('data-product-handle');\n          const variantTitle = this.getAttribute('data-variant-title');\n          \n          if (variantImage && whiteMainImage) whiteMainImage.src = variantImage;\n          if (variantPrice && whitePrice) whitePrice.innerHTML = variantPrice;\n          if (whiteAddToCart) whiteAddToCart.setAttribute('data-variant-id', variantId);\n          \n          whiteVariants.forEach(b => {\n            b.style.background = 'white';\n            b.style.color = 'black';\n          });\n          this.style.background = '#000';\n          this.style.color = 'white';\n          \n          await onWhiteVariantClick(productHandle, variantTitle);\n        });\n      });\n      \n      if (whiteAddToCart) {\n        whiteAddToCart.addEventListener('click', function(e) {\n          e.preventDefault();\n          const variantId = this.getAttribute('data-variant-id');\n          if (variantId && variantId !== '') {\n            addToCart(variantId, this);\n          } else {\n            alert('Please select a variant first');\n          }\n        });\n      }\n    }\n    \n    // ========== Functional 产品 ==========\n    const functionalVariants = document.querySelectorAll('.functional-variant-btn');\n    const functionalMainImage = document.getElementById('functional-main-image');\n    const functionalPrice = document.getElementById('functional-price');\n    const functionalAddToCart = document.getElementById('functional-add-to-cart');\n    \n    if (functionalVariants.length > 0) {\n      functionalVariants.forEach(btn => {\n        btn.addEventListener('click', async function(e) {\n          e.preventDefault();\n          \n          const variantId = this.getAttribute('data-variant-id');\n          const variantImage = this.getAttribute('data-variant-image');\n          const variantPrice = this.getAttribute('data-variant-price');\n          const productHandle = this.getAttribute('data-product-handle');\n          const variantTitle = this.getAttribute('data-variant-title');\n          \n          if (variantImage && functionalMainImage) functionalMainImage.src = variantImage;\n          if (variantPrice && functionalPrice) functionalPrice.innerHTML = variantPrice;\n          if (functionalAddToCart) functionalAddToCart.setAttribute('data-variant-id', variantId);\n          \n          functionalVariants.forEach(b => {\n            b.style.background = 'white';\n            b.style.color = 'black';\n          });\n          this.style.background = '#000';\n          this.style.color = 'white';\n          \n          await onFunctionalVariantClick(productHandle, variantTitle);\n        });\n      });\n      \n      if (functionalAddToCart) {\n        functionalAddToCart.addEventListener('click', function(e) {\n          e.preventDefault();\n          const variantId = this.getAttribute('data-variant-id');\n          if (variantId && variantId !== '') {\n            addToCart(variantId, this);\n          } else {\n            alert('Please select a variant first');\n          }\n        });\n      }\n    }\n  }\n  \n  // 通用加购函数\n  window.addToCart = function(variantId, btn) {\n    fetch('/cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })\n    })\n    .then(response => {\n      if (response.ok) {\n        const originalText = btn.innerText;\n        btn.innerText = '✓ Added!';\n        setTimeout(() => { btn.innerText = originalText; }, 1500);\n      } else {\n        alert('Error adding to cart');\n      }\n    })\n    .catch(() => alert('Error adding to cart'));\n  };\n  \n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>",
        "color_scheme": "",
