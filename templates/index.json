        "custom_liquid": "<style>\n/* 完全和Banner同宽，视频居中显示 */\n.video-carousel {\n  width: 100% !important;\n  max-width: 100% !important;\n  aspect-ratio: 16 / 6;\n  margin: 0 auto;\n  overflow: hidden;\n  position: relative;\n  background: transparent;\n}\n\n.video-slides {\n  display: flex;\n  width: 200%;\n  height: 100%;\n  transition: transform 0.4s ease;\n}\n\n.video-slide {\n  width: 50%;\n  height: 100%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.video-slide video {\n  width: 78%;\n  height: 100%;\n  object-fit: cover;\n  outline: none;\n  border: none;\n  display: block;\n}\n\n/* 左右箭头 */\n.carousel-arrow {\n  position: absolute;\n  top: 50%;\n  transform: translateY(-50%);\n  background: rgba(0,0,0,0.4);\n  color: white;\n  border: none;\n  width: 44px;\n  height: 44px;\n  border-radius: 50%;\n  font-size: 20px;\n  cursor: pointer;\n  z-index: 99;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.prev { left: 20px; }\n.next { right: 20px; }\n</style>\n\n<div class=\"video-carousel\">\n  <div class=\"video-slides\">\n    <div class=\"video-slide\">\n      <video controls muted playsinline>\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/936345c0913d4e6b9335d54f21d56ca4.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n    <div class=\"video-slide\">\n      <video controls muted playsinline>\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/c9dd4b3bbb124063a0b3d3115c902628.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n  </div>\n\n  <button class=\"carousel-arrow prev\">←</button>\n  <button class=\"carousel-arrow next\">→</button>\n</div>\n\n<script>\nconst slides = document.querySelector('.video-slides');\nconst prev = document.querySelector('.prev');\nconst next = document.querySelector('.next');\nconst videos = document.querySelectorAll('video');\nlet index = 0;\nlet carouselInterval;\nlet isPlaying = false;\n\n// 更新轮播位置\nfunction update() {\n  slides.style.transform = `translateX(-${index * 50}%)`;\n}\n\n// 启动自动轮播（5秒切换）\nfunction startCarousel() {\n  if (carouselInterval) clearInterval(carouselInterval);\n  carouselInterval = setInterval(() => {\n    if (!isPlaying) {\n      index = index === 1 ? 0 : 1;\n      update();\n    }\n  }, 5000);\n}\n\n// 左右箭头点击 + 重置计时器\nprev.addEventListener('click', () => {\n  index = index === 0 ? 1 : 0;\n  update();\n  startCarousel(); // 手动切换后重置倒计时\n});\n\nnext.addEventListener('click', () => {\n  index = index === 1 ? 0 : 1;\n  update();\n  startCarousel(); // 手动切换后重置倒计时\n});\n\n// 视频播放时暂停轮播\nvideos.forEach(video => {\n  video.addEventListener('play', () => {\n    isPlaying = true;\n  });\n  video.addEventListener('pause', () => {\n    isPlaying = false;\n  });\n  video.addEventListener('ended', () => {\n    isPlaying = false;\n  });\n});\n\n// 初始化启动\nstartCarousel();\n</script>",
