        "custom_liquid": "<div style=\"position: relative; width: 100%; background: #fff; overflow: hidden;\">\n  <div id=\"videoCarousel\" style=\"display: flex; width: 200%; transition: transform 0.4s ease;\">\n    <div style=\"width: 50%; display: flex; justify-content: center; align-items: center; background: #fff;\">\n      <video id=\"video1\" width=\"80%\" controls muted playsinline style=\"display: block; background: #fff;\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/936345c0913d4e6b9335d54f21d56ca4.mp4\" type=\"video/mp4\">\n        Your browser does not support the video tag.\n      </video>\n    </div>\n    <div style=\"width: 50%; display: flex; justify-content: center; align-items: center; background: #fff;\">\n      <video id=\"video2\" width=\"80%\" controls muted playsinline style=\"display: block; background: #fff;\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/c9dd4b3bbb124063a0b3d3115c902628.mp4\" type=\"video/mp4\">\n        Your browser does not support the video tag.\n      </video>\n    </div>\n  </div>\n\n  <button id=\"prevBtn\" style=\"position: absolute; top: 50%; left: 20px; transform: translateY(-50%); background: rgba(0,0,0,0.4); color: white; border: none; width: 44px; height: 44px; border-radius: 50%; font-size: 20px; cursor: pointer; z-index: 99;\">←</button>\n  <button id=\"nextBtn\" style=\"position: absolute; top: 50%; right: 20px; transform: translateY(-50%); background: rgba(0,0,0,0.4); color: white; border: none; width: 44px; height: 44px; border-radius: 50%; font-size: 20px; cursor: pointer; z-index: 99;\">→</button>\n</div>\n\n<script>\n(function() {\n  const carousel = document.getElementById('videoCarousel');\n  const prevBtn = document.getElementById('prevBtn');\n  const nextBtn = document.getElementById('nextBtn');\n  const video1 = document.getElementById('video1');\n  const video2 = document.getElementById('video2');\n  const videos = [video1, video2];\n  \n  let currentIndex = 0;\n  let autoTimer = null;\n  let isPlaying = false;\n\n  // 暂停所有视频\n  function pauseAll() {\n    videos.forEach(v => { if (v && !v.paused) v.pause(); });\n    isPlaying = false;\n  }\n\n  // 切换到指定视频\n  function switchTo(index, resetProgress = true) {\n    if (currentIndex === index && resetProgress === false) return;\n    \n    // 先暂停所有视频\n    pauseAll();\n    \n    // 移动轮播\n    currentIndex = index;\n    if (carousel) {\n      carousel.style.transform = `translateX(-${currentIndex * 50}%)`;\n    }\n    \n    // 重置进度\n    if (resetProgress && videos[currentIndex]) {\n      videos[currentIndex].currentTime = 0;\n    }\n    \n    // 重启自动轮播计时\n    restartAuto();\n  }\n\n  // 自动轮播\n  function startAuto() {\n    if (autoTimer) clearInterval(autoTimer);\n    autoTimer = setInterval(() => {\n      if (!isPlaying) {\n        const next = currentIndex === 0 ? 1 : 0;\n        switchTo(next, true);\n      }\n    }, 5000);\n  }\n  \n  function restartAuto() {\n    if (autoTimer) {\n      clearInterval(autoTimer);\n      startAuto();\n    }\n  }\n\n  // 监听视频播放状态\n  function initVideoListeners() {\n    videos.forEach((video, idx) => {\n      if (!video) return;\n      \n      video.addEventListener('play', () => {\n        isPlaying = true;\n        // 确保其他视频暂停\n        videos.forEach((v, i) => {\n          if (i !== idx && v && !v.paused) v.pause();\n        });\n      });\n      \n      video.addEventListener('pause', () => {\n        const anyPlaying = videos.some(v => v && !v.paused);\n        if (!anyPlaying) isPlaying = false;\n      });\n      \n      video.addEventListener('ended', () => {\n        video.pause();\n        video.currentTime = 0;\n        isPlaying = false;\n        // 视频结束后自动切换到下一个\n        const next = currentIndex === 0 ? 1 : 0;\n        switchTo(next, true);\n      });\n    });\n  }\n\n  // 按钮事件\n  if (prevBtn) {\n    prevBtn.addEventListener('click', () => {\n      const newIdx = currentIndex === 0 ? 1 : 0;\n      switchTo(newIdx, true);\n      restartAuto();\n    });\n  }\n  \n  if (nextBtn) {\n    nextBtn.addEventListener('click', () => {\n      const newIdx = currentIndex === 0 ? 1 : 0;\n      switchTo(newIdx, true);\n      restartAuto();\n    });\n  }\n\n  // 初始化\n  initVideoListeners();\n  pauseAll();\n  if (video1) video1.currentTime = 0;\n  if (video2) video2.currentTime = 0;\n  startAuto();\n})();\n</script>",
